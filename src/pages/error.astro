---
import BaseLayout from "../layouts/BaseLayout.astro";
import NoSeoHead from "../components/NoSeoHead.astro";
---

<BaseLayout>
  <NoSeoHead title="Error Page" description="Something has gone awry..." />
  <main class="h-screen min-h-[512px] p-12 relative overflow-hidden">
    <div class="flex flex-col-reverse lg:flex-row h-full w-full border-4">
      <div class="flex flex-col animate-fade-in p-8 justify-end">
        <div class="flex flex-col space-y-2">
          <a
            href="/"
            class="text-2xl text-indigo-400 cursor-pointer hover:bg-teal-400 hover:text-white align-middle"
            >Home</a
          >
          <a
            href="/profile"
            class="text-2xl text-indigo-400 cursor-pointer hover:bg-teal-400 hover:text-white align-middle"
            >Profile</a
          >
          <a
            href="/articles"
            class="text-2xl text-indigo-400 cursor-pointer hover:bg-teal-400 hover:text-white align-middle"
            >Articles</a
          >
          <a
            href="/contact"
            class="text-2xl text-indigo-400 cursor-pointer hover:bg-teal-400 hover:text-white"
            >Contact</a
          >
          <span class="text-slate-600 text-xs select-none"
            >© Robert Shalders, 2025</span
          >
        </div>
      </div>
      <div
        class="flex flex-col gap-y-8 justify-center items-center w-full p-4 lg:p-0 mb-16 lg:m-9"
      >
        <div class="flex flex-col justify-center items-center gap-y-4">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="64"
            height="64"
            fill="currentColor"
            class="bi bi-bug-fill"
            viewBox="0 0 16 16"
          >
            <path
              d="M4.978.855a.5.5 0 1 0-.956.29l.41 1.352A5 5 0 0 0 3 6h10a5 5 0 0 0-1.432-3.503l.41-1.352a.5.5 0 1 0-.956-.29l-.291.956A5 5 0 0 0 8 1a5 5 0 0 0-2.731.811l-.29-.956z"
            ></path>
            <path
              d="M13 6v1H8.5v8.975A5 5 0 0 0 13 11h.5a.5.5 0 0 1 .5.5v.5a.5.5 0 1 0 1 0v-.5a1.5 1.5 0 0 0-1.5-1.5H13V9h1.5a.5.5 0 0 0 0-1H13V7h.5A1.5 1.5 0 0 0 15 5.5V5a.5.5 0 0 0-1 0v.5a.5.5 0 0 1-.5.5zm-5.5 9.975V7H3V6h-.5a.5.5 0 0 1-.5-.5V5a.5.5 0 0 0-1 0v.5A1.5 1.5 0 0 0 2.5 7H3v1H1.5a.5.5 0 0 0 0 1H3v1h-.5A1.5 1.5 0 0 0 1 11.5v.5a.5.5 0 1 0 1 0v-.5a.5.5 0 0 1 .5-.5H3a5 5 0 0 0 4.5 4.975"
            ></path>
          </svg>
          <span class="text-2xl">Something went wrong...</span>
        </div>
      </div>
    </div>
    <div class="absolute animated-background -z-10 animate-shift inset-[-100%]">
    </div>
  </main>
</BaseLayout>
