---
import BaseLayout from "../layouts/BaseLayout.astro";
import NoSeoHead from "../components/NoSeoHead.astro";
import Navigation from "../components/Navigation.astro";
---

<BaseLayout>
  <NoSeoHead slot="head" title="Profile" description="..." />
  <main class="h-svh min-h-128 md:p-12 p-8 relative overflow-hidden">
    <div class="flex flex-col-reverse lg:flex-row h-full w-full border-4">
      <Navigation />
      <div class="flex justify-center items-center h-full w-full">
        <div class="flex flex-col justify-center items-center gap-y-4">
          <h2 class="font-bold mb-2 flicker-a">
            STATUS: WORK_IN_PROGRESS
          </h2>
        </div>
      </div>
    </div>
    <div class="absolute animated-background -z-10 animate-shift -inset-full">
    </div>
  </main>
</BaseLayout>
